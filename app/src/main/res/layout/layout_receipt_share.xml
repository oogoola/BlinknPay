<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="400dp"
    android:layout_height="wrap_content"
    android:background="@android:color/white"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/receiptBranding"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="BlinknPay"
        android:textColor="#6CAF10"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:background="#EEEEEE" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Amount Paid"
        android:textAllCaps="true"
        android:textColor="#888888"
        android:textSize="12sp"
        android:gravity="center" />

    <TextView
        android:id="@+id/receiptAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="KSh 0.00"
        android:textColor="#333333"
        android:textSize="32sp"
        android:textStyle="bold"
        android:gravity="center" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recipient/Sender"
            android:textColor="#888888"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/receiptParty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Merchant Name"
            android:textColor="#333333"
            android:textSize="16sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#F5F5F5" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Transaction Reference"
            android:textColor="#888888"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/receiptRef"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RCL812J9KL"
            android:textColor="#333333"
            android:textSize="16sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#F5F5F5" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Date &amp; Time"
            android:textColor="#888888"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/receiptDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="08 Mar 2026, 10:30 PM"
            android:textColor="#333333"
            android:textSize="16sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/receiptStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="32dp"
        android:background="#E8F5E9"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:text="COMPLETED"
        android:textColor="#2E7D32"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Generated via BlinknPay Unified Engine"
        android:textColor="#BBBBBB"
        android:textSize="10sp"
        android:gravity="center" />

</LinearLayout>